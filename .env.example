# API Configuration
API_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4.1-mini

# LLM Integration (set to true only with valid API key)
USE_LLM=false

# API Key (only needed if USE_LLM=true)
# For OpenAI: sk-...
# For Hugging Face: hf_...
HF_TOKEN=your_api_key_here

# Logging
LOG_LEVEL=INFO

# Docker
LOCAL_IMAGE_NAME=cyber-incident-openenv:latest
